@page
@model RecreaLearnAspNet.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-page">
    <div class="auth-card">
        <span class="auth-kicker">Welcome back</span>
        <h1>Sign in to continue learning</h1>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="notice danger">@Model.Message</div>
        }

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />

            <label>Email</label>
            <input asp-for="Email" type="email" placeholder="you@example.com" required />

            <label>Password</label>
            <input asp-for="Password" type="password" placeholder="Password" required />

            <button class="btn btn-primary" type="submit">Sign In</button>
        </form>

        <p class="small">
            No account yet?
            <a asp-page="/Register">Create one</a>
        </p>
    </div>
</section>
